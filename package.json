{
  "name": "auditoo",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/web",
    "apps/api"
  ],
  "scripts": {
    "dev": "concurrently \"npx supabase start\" \"npm run dev --workspace=apps/api\" \"npm run dev --workspace=apps/web\"",
    "db:reset": "npx supabase db reset",
    "db:seed": "node --env-file apps/api/.env supabase/seed.js",
    "db:types": "npx supabase gen types typescript --local > database.types.ts",
    "lint": "eslint .",
    "test": "cypress run",
    "test:e2e": "cypress open"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@supabase/supabase-js": "^2.103.3",
    "concurrently": "^9.0.0",
    "cypress": "^14.5.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0"
  }
}
