# Copy to `apps/api/.env`. Loaded by API dev/start and by root `npm run db:seed`.
# Overview: repo `.env.example`, docs/SETUP.md §2.

SUPABASE_URL=http://localhost:54321
SUPABASE_SERVICE_ROLE_KEY=

OPENAI_API_KEY=
# Optional. Default `whisper-1` (browser WebM works reliably). `gpt-4o-transcribe` may reject some WebM uploads.
# VOICE_TRANSCRIPTION_MODEL=gpt-4o-transcribe

PORT=3001

# Optional: comma-separated browser origins (defaults to local Vite URLs if unset).
# Production: add your Vercel web URL, e.g. https://auditoo-web.vercel.app
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
